# Dev setup state (contains resource IDs, not secrets — but no need to commit)
.dev-state

# Terraform files
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!terraform.tfvars.example

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.env
.env.local

# Crash log files
crash.log
crash.*.log

# Exclude override files as they are often used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan

# Ignore lock files (optional, remove if you want to version lock files)
.terraform.lock.hcl
